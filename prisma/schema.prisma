generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Role define kiya (Admin aur User)
enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          Role      @default(USER) // 2. Yeh line role add karti hai
  bio           String?   @default("Freelance Web Developer") 
  createdAt     DateTime  @default(now())
  projects      Project[]
  image         String?   
  emailNotify   Boolean   @default(true)
  desktopNotify Boolean   @default(true)
  inquiryNotify Boolean   @default(true)
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("Todo")
  category    String?
  image       String?
  dueDate     DateTime? 

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?   @unique
  projects  Project[]
  invoices  Invoice[]
  createdAt DateTime  @default(now())
}

model Project {
  id          String    @id @default(cuid())
  title       String
  clientId    String
  status      String    @default("ACTIVE")
  budget      Float?
  description String? 
  image       String? 
  userId      String
  createdAt   DateTime @default(now())
  user        User      @relation(fields: [userId], references: [id])
  category    String @default("Web Development")
  tasks       Task[]
  client      Client    @relation(fields: [clientId], references: [id])
  invoices    Invoice[]
}

model Invoice {
  id        String @id @default(cuid())
  amount    Float
  status    String @default("PENDING")
  clientId String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Stat {
  id        String   @id @default(cuid())
  label     String
  value     String
  change    String
  icon      String?
  createdAt DateTime @default(now())
}